data/processed/*
!data/processed/.gitkeep
data/final/*
!data/final/.gitkeep

# Modelos y artefactos
# Permitimos archivos .pkl (encoders/scalers) porque son pequeños y necesarios
models/*.pkl
!models/.gitkeep

